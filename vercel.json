{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "fonts/**"
      }
    }
  ],
  "rewrites": [
    { "source": "/webhook", "destination": "/api/webhook.py" },
    { "source": "/", "destination": "/api/webhook.py" }
  ],
  "env": {
    "BOT_TOKEN": "",
    "BOT_USERNAME": "",
    "ADMIN_IDS": "",
    "STORAGE_BACKEND": "",
    "REDIS_URL": ""
  }
}
