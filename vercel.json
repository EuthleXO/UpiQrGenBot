{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "fonts/**"
      }
    }
  ],
  "rewrites": [
    { "source": "/webhook", "destination": "/api/webhook.py" },
    { "source": "/", "destination": "/api/webhook.py" }
  ],
  "env": {
    "BOT_TOKEN": "@bot_token",
    "BOT_USERNAME": "@bot_username",
    "ADMIN_IDS": "@admin_ids",
    "STORAGE_BACKEND": "@storage_backend",
    "REDIS_URL": "@redis_url"
  }
}
