# Copy this file to .env for local development (and never commit the real .env).
# On Vercel, set these as Environment Variables in the project dashboard instead.

# Required — get this from @BotFather on Telegram
BOT_TOKEN=

# Your bot's username, without the @
BOT_USERNAME=UpiQrGenBot

# Comma-separated Telegram user IDs allowed to use /admin
ADMIN_IDS=

# Storage backend: memory | json | redis
# - memory : in-process only, resets on every cold start (fine for quick tests)
# - json   : writes to users.json on local disk (local dev / VPS only)
# - redis  : persistent storage, required for real production use on Vercel
STORAGE_BACKEND=memory

# Required only when STORAGE_BACKEND=redis
REDIS_URL=

